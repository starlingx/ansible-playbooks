---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: stx-multipath-config-enforcer
  namespace: {{ trident_namespace }}
spec:
  selector:
    matchLabels:
      app: stx-multipath-config-enforcer
  template:
    metadata:
      labels:
        app: stx-multipath-config-enforcer
    spec:
      hostPID: true
      containers:
      - name: multipath-enforcer
        image: {{ local_registry }}/docker.io/library/busybox:1.37.0
        command: ["/bin/sh", "-c"]
        args:
        - |
          set -e

          MULTIPATH_CONF="/host/etc/multipath.conf"

          # Print the verification time
          date

          # Check if the file exists
          if [ -f "$MULTIPATH_CONF" ]; then
            # Extract the find_multipaths value
            FIND_MULTIPATHS=$(grep -E "^[[:space:]]*find_multipaths" "$MULTIPATH_CONF" | awk '{print $2}')

            # If the find_multipaths was not found
            if [ -z "$FIND_MULTIPATHS" ]; then
              echo "The option find_multipaths was not found in the config file. \
              By default, the value is already 'no'."
            # If the value is different from 'no'
            elif [ "$FIND_MULTIPATHS" != "no" ]; then
              echo "find_multipaths is currently set to '$FIND_MULTIPATHS'. Changing it to 'no'..."
              sed -i 's/^\([[:space:]]*find_multipaths[[:space:]]\+\)\(yes\|smart\)/\1no/' "$MULTIPATH_CONF"
              echo "Enforced find_multipaths to 'no' in $MULTIPATH_CONF"
            else
              echo "find_multipaths is already set to 'no'. Nothing to do."
            fi

            # Checks if the block does not exist
            if ! grep -q "BEGIN TRIDENT CONFIG" "$MULTIPATH_CONF"; then
              echo "Adding blacklist and exceptions to multipath.conf"
              TRIDENT_BLOCK=$(cat <<EOF
          # BEGIN TRIDENT CONFIG
          blacklist {
              device {
                  vendor ".*"
              }
          }

          blacklist_exceptions {
              property "(SCSI_IDENT_|ID_WWN)"
              device {
                  vendor "3PARdata"
              }
              device {
                  vendor "QEMU"
              }
              device {
                  vendor "TrueNAS"
              }
              device {
                  vendor "DellEMC"
              }
              device {
                  vendor "NETAPP"
              }
          }
          # END TRIDENT CONFIG
          EOF
          )
              # Add to the end of the file
              echo "$TRIDENT_BLOCK" >> "$MULTIPATH_CONF"
            else
              echo "Blacklist and exceptions already exist."
            fi

            echo "Restarting multipathd service..."
            chroot /host /bin/systemctl restart multipathd
            echo "Multipath configuration enforced successfully."
          else
            echo "$MULTIPATH_CONF not found."
          fi

          echo "Sleeping until the next boot..."
          sleep infinity
        volumeMounts:
        - name: host-system
          mountPath: /host
        securityContext:
          privileged: true
      volumes:
      - name: host-system
        hostPath:
          path: /
      tolerations:
        - operator: "Exists"
      imagePullSecrets:
        - name: {{ trident_secret_name }}

from oslo_config import cfg
from sysinv.common import constants
from sysinv.common import utils
from sysinv.conductor import kube_app
from sysinv.db import api
import functools
import eventlet

eventlet.monkey_patch()

import logging
import sys
import warnings

# To supress SQLAlchemy warnings
warnings.filterwarnings("ignore", category=DeprecationWarning)
warnings.filterwarnings("ignore", message="relationship '.*' will copy column")

LOG_FILE = "{{ tmp_workspace }}/download_images.log"

_file_handler = logging.FileHandler(LOG_FILE)
_file_handler.setLevel(logging.INFO)
_file_handler.setFormatter(logging.Formatter("%(asctime)s [%(levelname)s] %(message)s"))

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.StreamHandler(sys.stdout),
        _file_handler,
    ]
)

logger = logging.getLogger(__name__)

cfg.CONF(default_config_files=['/etc/sysinv/sysinv.conf'])

dbapi = api.get_instance()
_docker = kube_app.DockerHelper(dbapi)


from sysinv.conductor import kube_app

rpc_app = dbapi.kube_app_get(constants.HELM_APP_PLATFORM)

app = kube_app.AppOperator.Application(rpc_app)

images_to_download = {{ images_to_download }}

registries_info = _docker.retrieve_specified_registries()
local_registry_auth = utils.get_local_docker_registry_auth()
docker_registry_server = constants.DOCKER_REGISTRY_SERVER

pool = eventlet.greenpool.GreenPool(size={{ max_parallel_download | int }})
for tag, success in pool.imap(
    functools.partial(_docker.download_an_image,
                      app,
                      registries_info),
                      images_to_download):
    if success:
        logger.info("Image downloaded successfully: %s", tag)
        _file_handler.flush()
    else:
        logger.error("Failed to download image: %s", tag)
        _file_handler.flush()
        raise Exception("Some images were not downloaded")

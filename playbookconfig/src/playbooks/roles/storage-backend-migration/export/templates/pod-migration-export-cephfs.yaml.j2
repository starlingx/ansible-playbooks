apiVersion: v1
kind: Pod
metadata:
  name: migration-export-cephfs
  namespace: {{ cephfs_pvc_namespace }}
spec:
  nodeName: {{ inventory_hostname }}
  hostNetwork: true
  containers:
    - name: migration-export-cephfs
      image: {{ images.ceph_config_helper }}
      command: [ "sleep", "infinity" ]
      volumeMounts:
        - mountPath: "/data"
          name: data
        - mountPath: /backup
          name: backup-data
  imagePullSecrets:
    - name: rook-migration-registry-local-secret
  volumes:
    - name: data
      persistentVolumeClaim:
        claimName: {{ pvc_name }}
    - name: backup-data
      hostPath:
        path: {{ backups_cephfs_path }}

---
# RBAC for Envoy Gateway to watch XListenerSet resources.
# Required when XListenerSet feature flag is enabled in the EnvoyGateway configuration.
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: envoy-gateway-xlistenerset
rules:
  - apiGroups: ["gateway.networking.x-k8s.io"]
    resources: ["xlistenersets"]
    verbs: ["get", "list", "watch"]
  - apiGroups: ["gateway.networking.x-k8s.io"]
    resources: ["xlistenersets/status"]
    verbs: ["get", "update", "patch"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: envoy-gateway-xlistenerset
subjects:
  - kind: ServiceAccount
    name: envoy-gateway
    namespace: tigera-gateway
roleRef:
  kind: ClusterRole
  name: envoy-gateway-xlistenerset
  apiGroup: rbac.authorization.k8s.io
